{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/grammar.schema.json",
  "name": "rafta_nvim",
  "rules": {
    "source_file": {
      "type": "REPEAT",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "task"
              },
              {
                "type": "STRING",
                "value": "\n"
              }
            ]
          },
          {
            "type": "SYMBOL",
            "name": "task"
          }
        ]
      }
    },
    "task": {
      "type": "CHOICE",
      "members": [
        {
          "type": "PREC",
          "value": 10,
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "SYMBOL",
                "name": "lhs"
              },
              {
                "type": "SYMBOL",
                "name": "title"
              }
            ]
          }
        },
        {
          "type": "PREC",
          "value": 9,
          "content": {
            "type": "SYMBOL",
            "name": "lhs"
          }
        },
        {
          "type": "PREC",
          "value": 1,
          "content": {
            "type": "SYMBOL",
            "name": "title"
          }
        }
      ]
    },
    "lhs": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "short_id"
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "state"
                },
                {
                  "type": "BLANK"
                }
              ]
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "priority"
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          ]
        },
        {
          "type": "SEQ",
          "members": [
            {
              "type": "SYMBOL",
              "name": "state"
            },
            {
              "type": "CHOICE",
              "members": [
                {
                  "type": "SYMBOL",
                  "name": "priority"
                },
                {
                  "type": "BLANK"
                }
              ]
            }
          ]
        },
        {
          "type": "SYMBOL",
          "name": "priority"
        }
      ]
    },
    "short_id": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "/"
            },
            {
              "type": "PATTERN",
              "value": "[0-9A-Fa-f]+"
            }
          ]
        }
      }
    },
    "state": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "PATTERN",
          "value": "[x.~\\-?]"
        }
      }
    },
    "priority": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 5,
        "content": {
          "type": "SEQ",
          "members": [
            {
              "type": "STRING",
              "value": "("
            },
            {
              "type": "PATTERN",
              "value": "[0-9]+"
            },
            {
              "type": "STRING",
              "value": ")"
            }
          ]
        }
      }
    },
    "title": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": -5,
        "content": {
          "type": "PATTERN",
          "value": "[^\\r\\n]*"
        }
      }
    }
  },
  "extras": [
    {
      "type": "PATTERN",
      "value": "[ \\t]"
    }
  ],
  "conflicts": [
    [
      "lhs"
    ]
  ],
  "precedences": [],
  "externals": [],
  "inline": [],
  "supertypes": [],
  "reserved": {}
}